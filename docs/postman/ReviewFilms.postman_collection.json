    "name": "ReviewFilms API",
    "description": "Postman collection for ReviewFilms API endpoints. Set `baseUrl` to your running API host before testing.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "movieId", "value": "00000000-0000-0000-0000-000000000001" },
    { "key": "genreId", "value": "00000000-0000-0000-0000-000000000002" },
    { "key": "commentId", "value": "00000000-0000-0000-0000-000000000003" },
